    "safety.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep returns automatically on low battery, high temperature, or lease expiry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "低电量、温度过高或租约失效时会自动恢复合盖睡眠。" } } } },
    "safety.approval" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Approve AwakeMac in Login Items & Extensions, then try again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在“登录项与扩展”中批准醒着，然后重试。" } } } },
