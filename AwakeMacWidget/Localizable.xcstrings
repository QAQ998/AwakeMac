    "lid.alert.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Running with the lid closed may generate heat and use battery. AwakeMac restores lid sleep below 20% battery, under serious thermal pressure, or if its safety lease expires." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖后持续运行可能产生热量并消耗电池。电量低于 20%、温度过高或安全租约失效时，醒着会恢复合盖睡眠。" } } } },
    "lid.alert.continue" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Continue and Open System Settings…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "继续并打开系统设置…" } } } },
    "lid.alert.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Experimental Lid Mode?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用实验性合盖模式？" } } } },
    "lid.approvalRequired" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Approve the helper in System Settings" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在系统设置中批准助手" } } } },
    "lid.enableWakeFirst" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn on Stay Awake first" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请先开启保持唤醒" } } } },
    "lid.experimental" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Experimental; first-use approval required" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "实验功能，首次使用需要批准" } } } },
    "lid.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stay awake with lid closed" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖仍保持运行" } } } },
    "lid.unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This Mac has no lid sleep feature" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此 Mac 没有合盖睡眠功能" } } } },
    "notification.battery.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored because battery reached 20%." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "电量已降至 20%，合盖睡眠已恢复。" } } } },
    "notification.safety.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid Sleep Restored" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已恢复合盖睡眠" } } } },
    "notification.thermal.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored because the Mac is under thermal pressure." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Mac 温度压力过高，合盖睡眠已恢复。" } } } },
    "notification.timer.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The wake timer ended and original sleep behavior is active again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保持唤醒计时已结束，Mac 已恢复原有睡眠行为。" } } } },
    "notification.timer.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Wake Session Ended" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保持唤醒已结束" } } } },
    "quit.stop" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop and Quit" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关闭并退出" } } } },
