    "duration.custom.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter a value from 1 minute to 24 hours." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请输入 1 分钟到 24 小时之间的时长。" } } } },
