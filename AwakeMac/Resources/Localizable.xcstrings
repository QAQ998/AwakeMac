    "widget.systemSettings" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Using system settings" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "使用系统设置" } } } }
