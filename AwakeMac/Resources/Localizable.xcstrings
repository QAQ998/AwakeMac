    "automation.choose" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选择" } } } },
    "automation.exitGrace" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop after app quits" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 退出后关闭" } } } },
    "automation.grace.immediately" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Immediately" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "立即" } } } },
    "automation.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The normal wake mode starts with the selected app. Reopening it during the grace period cancels shutdown." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "指定 App 运行时自动开启普通唤醒；缓冲期内重新打开会取消关闭。" } } } },
    "automation.invalidApp" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The selected item is not a valid macOS app." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "所选项目不是有效的 macOS App。" } } } },
    "automation.chooseFirst" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose an app before enabling App Link." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请先选择一个 App，再开启联动。" } } } },
    "automation.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Kept awake by %@" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在跟随 %@ 保持唤醒" } } } },
    "automation.exitCountdown" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ quit · stopping in %d:%02d" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ 已退出，%d:%02d 后关闭" } } } },
    "automation.notificationTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "App Link Ended" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 联动已结束" } } } },
    "automation.notificationBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The selected app stayed closed, so original sleep behavior is active again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "指定 App 已持续退出，Mac 已恢复原有睡眠行为。" } } } },
    "quickAway.settings.section" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick Break" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂离功能" } } } },
    "quickAway.settings.introduction" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "When you step away briefly, AwakeMac keeps the computer awake for the selected duration and lowers supported displays to the chosen brightness. It asks for confirmation before starting and restores brightness when the session ends." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "短暂离开时，醒着会在设定时间内保持电脑唤醒，并把支持的显示器调到所选亮度；每次开启前都会二次确认，结束后自动恢复原亮度。" } } } },
    "quickAway.settings.copyStyle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Copy style" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "文案风格" } } } },
    "quickAway.style.aquatic" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Field Research" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "水产调研" } } } },
    "quickAway.style.cyber" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cyber Cover" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "赛博托管" } } } },
    "quickAway.settings.duration" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Duration" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "托管时长" } } } },
    "quickAway.settings.brightness" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Brightness" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "亮度档位" } } } },
    "quickAway.settings.detail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Starting this always asks for confirmation and replaces the current wake session. Brightness is restored when it ends." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每次开启都需要确认，并会替换当前唤醒会话；结束后自动恢复亮度。" } } } },
    "quickAway.open" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Start" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开始" } } } },
    "quickAway.defaultDetail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%d min · brightness %d/64" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "低亮度保持唤醒 %d 分钟 · %d/64" } } } },
    "quickAway.activeRemaining" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ · %d min left" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ · 剩余 %d 分钟" } } } },
    "quickAway.replacesSession" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The current wake session will be replaced and lid mode will safely turn off." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前唤醒会话将被替换，合盖模式也会安全退出。" } } } },
    "quickAway.noAdjustableDisplay" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No adjustable display was detected. Wake mode will still start without changing brightness." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "未检测到可调亮度的显示器；仍会保持唤醒，但不会调整亮度。" } } } },
    "quickAway.restoreFailed" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Some display brightness levels could not be restored. Please adjust them manually." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "部分显示器亮度未能恢复，请手动接管一下。" } } } },
    "quickAway.aquatic.start" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Start Field Research" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开始水产调研" } } } },
    "quickAway.aquatic.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Research in progress" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "调研中" } } } },
    "quickAway.aquatic.return" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Back to Work" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "收网回岗" } } } },
    "quickAway.aquatic.confirmTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ready to dive in?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "确定要下水吗？" } } } },
    "quickAway.aquatic.confirmBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "For the next %d minutes, AwakeMac will keep watch and lower display brightness to %d/64." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "接下来 %d 分钟，醒着会替你守好工位，并把屏幕亮度降至 %d/64。" } } } },
    "quickAway.aquatic.confirm" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dive In" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "下水调研" } } } },
    "quickAway.aquatic.cancel" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stay Ashore" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "留在岸上" } } } },
    "quickAway.aquatic.notificationTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Field Research Complete" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "水产调研已结束" } } } },
    "quickAway.aquatic.notificationBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The nets are in. Brightness and normal sleep behavior have been restored." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已经收网，屏幕亮度与原有睡眠行为均已恢复。" } } } },
    "quickAway.cyber.start" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Let Me Cover Your Shift" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "让本帅替会儿班" } } } },
    "quickAway.cyber.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I’m covering your shift" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本帅正在替你值班" } } } },
    "quickAway.cyber.return" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I’m Back" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我回来接班了" } } } },
    "quickAway.cyber.confirmTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hand the desk over to me?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "把工位交给本帅？" } } } },
    "quickAway.cyber.confirmBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "For the next %d minutes, I’ll stay awake and lower display brightness to %d/64." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "接下来 %d 分钟，本帅会保持清醒，并把屏幕亮度降至 %d/64。" } } } },
    "quickAway.cyber.confirm" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You’ve Got This" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "放心交班" } } } },
    "quickAway.cyber.cancel" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Not Yet" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "我再等等" } } } },
    "quickAway.cyber.notificationTitle" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "My Shift Is Over" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本帅下班了" } } } },
    "quickAway.cyber.notificationBody" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Shift complete. Brightness and normal sleep behavior have been restored." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本帅已完成本次值班，亮度与原有睡眠行为均已恢复。" } } } },
    "widget.lid.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid mode on" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖模式已开启" } } } },
    "widget.lid.noLid" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No lid" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无合盖功能" } } } },
    "widget.lid.off" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Advanced mode off" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "高级模式未开启" } } } },
    "widget.name" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Awake" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "醒着" } } } },
    "widget.start" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Start" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开启" } } } },
