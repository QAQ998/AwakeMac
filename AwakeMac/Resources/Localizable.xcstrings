    "helper.remove.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This restores lid sleep and removes AwakeMac’s root helper from this Mac. Administrator authorization is required." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "这会恢复合盖睡眠，并从本机移除醒着的 root 助手。操作需要管理员授权。" } } } },
    "helper.remove.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Remove the Local Helper?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "卸载本机助手？" } } } },
