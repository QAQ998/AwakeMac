    "lid.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Closed-lid mode is on" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖模式已开启" } } } },
    "lid.alert.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Running with the lid closed may generate heat and use battery. AwakeMac restores lid sleep below 20% battery, under serious thermal pressure, or if its safety lease expires." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖后持续运行可能产生热量并消耗电池。电量低于 20%、温度过高或安全租约失效时，醒着会恢复合盖睡眠。" } } } },
    "lid.alert.continue" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Continue and Install Helper…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "继续并安装助手…" } } } },
    "lid.alert.enable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Continue" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "继续" } } } },
    "lid.alert.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Experimental Lid Mode?" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "启用实验性合盖模式？" } } } },
    "lid.approvalRequired" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Approve the helper in System Settings" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在系统设置中批准助手" } } } },
    "lid.enableWakeFirst" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn on Stay Awake first" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请先开启保持唤醒" } } } },
    "lid.experimental" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Experimental; restores lid sleep after 90 seconds without contact" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "实验功能，应用失联 90 秒后自动恢复合盖睡眠" } } } },
    "lid.installing" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Installing the local helper…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在安装本机助手…" } } } },
    "login.approvalRequired" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Allow AwakeMac in Login Items & Extensions, then try again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在“登录项与扩展”中允许 AwakeMac，然后重试。" } } } },
    "lid.installRequired" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Local helper installation is required" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要安装本机助手" } } } },
    "lid.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stay awake with lid closed" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖仍保持运行" } } } },
    "lid.unavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This Mac has no lid sleep feature" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "此 Mac 没有合盖睡眠功能" } } } },
    "lid.updateRequired" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The local helper needs an update" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "本机助手需要更新" } } } },
    "notification.battery.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored because battery reached 20%." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "电量已降至 20%，合盖睡眠已恢复。" } } } },
    "notification.safety.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid Sleep Restored" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已恢复合盖睡眠" } } } },
    "notification.thermal.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored because the Mac is under thermal pressure." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Mac 温度压力过高，合盖睡眠已恢复。" } } } },
    "notification.timer.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The wake timer ended and original sleep behavior is active again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保持唤醒计时已结束，Mac 已恢复原有睡眠行为。" } } } },
    "notification.timer.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Wake Session Ended" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保持唤醒已结束" } } } },
    "quit.stop" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop and Quit" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关闭并退出" } } } },
    "remaining.hoursMinutes" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%d hr %d min remaining" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "剩余 %d 小时 %d 分钟" } } } },
    "remaining.minutes" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%d min remaining" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "剩余 %d 分钟" } } } },
    "remaining.seconds" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%d sec remaining" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "剩余 %d 秒" } } } },
    "safety.active" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep returns automatically on low battery, high temperature, or lease expiry." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "低电量、温度过高或租约失效时会自动恢复合盖睡眠。" } } } },
    "safety.approval" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Install the local helper with administrator authorization, then try again." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请使用管理员授权安装本机助手，然后重试。" } } } },
    "safety.helperUnavailable" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The lid helper is unavailable; normal wake mode still works." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖助手不可用，普通保持唤醒仍可使用。" } } } },
    "safety.lowBattery" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored at 20% battery." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "电量达到 20%，已恢复合盖睡眠。" } } } },
    "safety.thermal" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Lid sleep was restored because of thermal pressure." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "温度压力过高，已恢复合盖睡眠。" } } } },
    "settings.about" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关于" } } } },
    "settings.alwaysOn" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Always on" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "始终开启" } } } },
    "settings.batteryGuard" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Low-battery cutoff" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "低电量保护" } } } },
    "settings.defaultDuration" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Default duration" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "默认持续时间" } } } },
    "settings.experimentalNotice" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Closed-lid mode relies on a system capability that Apple does not publicly guarantee. The app renews its permission every 30 seconds; if contact is lost for 90 seconds, the helper restores normal lid sleep automatically. Battery and thermal protections can’t be disabled." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "合盖模式依赖 Apple 未公开承诺兼容性的系统能力。应用每 30 秒续约一次；连续 90 秒失联后，助手会自动恢复正常的合盖睡眠。电量和温度保护不可关闭。" } } } },
    "settings.general" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "General" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "通用" } } } },
