{
  "sourceLanguage" : "en",
  "strings" : {
    "about.description" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keeps your Mac awake without changing its original idle-sleep settings." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在不修改 Mac 原有空闲睡眠设置的前提下保持唤醒。" } } } },
